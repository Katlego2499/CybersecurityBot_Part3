<Window x:Class="CybersecurityBot_Part3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="700" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F3460" CornerRadius="10" Margin="5" Padding="10">
            <TextBlock Foreground="#E94560" FontFamily="Consolas" FontSize="12"
                       TextAlignment="Center" FontWeight="Bold"
                       Text="🔒 CYBERSECURITY AWARENESS BOT — PART 3"/>
        </Border>

        <TabControl Grid.Row="1" Margin="5" Background="#16213E" BorderBrush="#0F3460">

            <!-- TAB 1: CHATBOT -->
            <TabItem Header="💬 Chatbot" Foreground="White" Background="#0F3460">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="ChatDisplay" Grid.Row="0" Margin="5"
                             Background="#16213E" BorderBrush="#0F3460" BorderThickness="2" FontSize="13"/>
                    <Grid Grid.Row="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UserInput" Grid.Column="0" Height="40"
                                 Background="#0F3460" Foreground="White" FontSize="13"
                                 KeyDown="UserInput_KeyDown"/>
                        <Button Grid.Column="1" Content="Send" Width="80" Height="40"
                                Click="SendButton_Click" Background="#E94560" Foreground="White"/>
                        <Button Grid.Column="2" Content="Clear" Width="80" Height="40"
                                Click="ClearButton_Click" Background="#533483" Foreground="White"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 2: TASKS -->
            <TabItem Header="📋 Tasks" Foreground="White" Background="#0F3460">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0F3460" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Add New Task" Foreground="#E94560" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBox x:Name="TaskTitle" Height="32" Margin="0,3" Background="#16213E" Foreground="Gray" FontSize="12" Text="Task title (e.g. Enable 2FA)" GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>
                            <TextBox x:Name="TaskDesc" Height="32" Margin="0,3" Background="#16213E" Foreground="Gray" FontSize="12" Text="Task description" GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>
                            <TextBox x:Name="TaskReminder" Height="32" Margin="0,3" Background="#16213E" Foreground="Gray" FontSize="12" Text="Reminder (e.g. Remind me in 3 days) — optional" GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>
                            <TextBox x:Name="TaskDate" Height="32" Margin="0,3" Background="#16213E" Foreground="Gray" FontSize="12" Text="Date/timeframe (e.g. 2025-12-01) — optional" GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus"/>
                            <Button Content="➕ Add Task" Height="36" Margin="0,6,0,0"
                                    Background="#E94560" Foreground="White" FontWeight="Bold" Click="AddTask_Click"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="TaskStatusMsg" Grid.Row="1" Foreground="#4CAF50" FontSize="12" Margin="0,0,0,5" TextWrapping="Wrap"/>
                    <ListBox x:Name="TaskListBox" Grid.Row="2" Background="#16213E"
                             BorderBrush="#0F3460" BorderThickness="2" FontSize="12" Foreground="White"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="✅ Mark Complete" Width="140" Height="36" Margin="0,0,8,0"
                                Background="#4CAF50" Foreground="White" Click="MarkComplete_Click"/>
                        <Button Content="🗑️ Delete Task" Width="130" Height="36" Margin="0,0,8,0"
                                Background="#E94560" Foreground="White" Click="DeleteTask_Click"/>
                        <Button Content="🔄 Refresh" Width="100" Height="36"
                                Background="#0F3460" Foreground="White" Click="RefreshTasks_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 3: QUIZ -->
            <TabItem Header="🎮 Quiz" Foreground="White" Background="#0F3460">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🎮 Cybersecurity Quiz"
                               Foreground="#E94560" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="QuizQuestion" Grid.Row="1" Foreground="White" FontSize="13"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel x:Name="QuizOptions" Grid.Row="2" Margin="0,0,0,10"/>
                    <TextBlock x:Name="QuizFeedback" Grid.Row="3" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button x:Name="StartQuizBtn" Content="▶️ Start Quiz" Width="120" Height="36"
                                Background="#E94560" Foreground="White" FontWeight="Bold"
                                Margin="0,0,8,0" Click="StartQuiz_Click"/>
                        <TextBlock x:Name="QuizScore" Foreground="LightBlue" FontSize="13" VerticalAlignment="Center" Margin="10,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 4: ACTIVITY LOG -->
            <TabItem Header="📜 Activity Log" Foreground="White" Background="#0F3460">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📜 Recent Activity (Last 10 Actions)"
                               Foreground="#E94560" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListBox x:Name="LogListBox" Grid.Row="1" Background="#16213E"
                             BorderBrush="#0F3460" BorderThickness="2"
                             FontSize="12" Foreground="LightGreen" FontFamily="Consolas"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="🔄 Refresh Log" Width="130" Height="36" Margin="0,0,8,0"
                                Background="#0F3460" Foreground="White" Click="RefreshLog_Click"/>
                        <Button Content="📋 Show All" Width="120" Height="36"
                                Background="#533483" Foreground="White" Click="ShowAllLog_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
